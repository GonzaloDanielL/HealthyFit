---
import Button from '../ui/Button.astro';
import { Image } from 'astro:assets';
import logoImg from '../../images/logo.png';

const navLinks = [
  { href: '/',          label: 'Inicio' },
  { href: '/nosotros',  label: 'Nosotros' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/planes',    label: 'Planes' },
  { href: '/galeria',   label: 'Galería' },
  { href: '/contacto',  label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-[100] bg-[#0a0a0a]/85 backdrop-blur-md border-b border-red-600/15 transition-all duration-300">
  <div class="container-site flex items-center justify-between h-[4.5rem] gap-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline shrink-0" aria-label="HealthyFit - Ir al inicio">
      <Image src={logoImg} alt="HealthyFit Logo" width={36} height={36} class="w-9 h-9 object-contain" />
      <span class="font-display text-[1.375rem] font-semibold text-white tracking-[-0.01em]">
        Healthy<strong class="text-red-600 font-extrabold">Fit</strong>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center justify-center gap-1 flex-1" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-[0.9rem] font-medium px-3 py-1.5 rounded-md transition-all duration-200 tracking-[0.01em] ${
            currentPath === link.href 
              ? 'text-red-400 bg-red-600/10' 
              : 'text-[#a1a1a1] hover:text-white hover:bg-white/5'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA Button -->
    <div class="hidden lg:block shrink-0">
      <Button href="/planes" size="sm">
        Únete ahora
      </Button>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex flex-col gap-[5px] bg-transparent border-none cursor-pointer p-2 rounded-md transition-colors duration-200 hover:bg-white/5"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-[22px] h-[2px] bg-white rounded-[2px] transition-all duration-300"></span>
      <span class="block w-[22px] h-[2px] bg-white rounded-[2px] transition-all duration-300"></span>
      <span class="block w-[22px] h-[2px] bg-white rounded-[2px] transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 bg-[#0a0a0a]/98 border-b border-[#2a2a2a] backdrop-blur-md" role="dialog" aria-label="Menú móvil">
    <nav class="flex flex-col p-4 px-6 gap-1 pb-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-base font-medium px-4 py-3 rounded-lg transition-all duration-200 ${
            currentPath === link.href 
              ? 'text-red-400 bg-red-600/10' 
              : 'text-[#a1a1a1] hover:text-white hover:bg-red-600/10'
          }`}
        >
          {link.label}
        </a>
      ))}
      <Button href="/planes" size="sm" class="mt-3">
        Únete ahora
      </Button>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    // -------------------------------------------------------------------------
    // Efecto de Transparencia/Opacidad al hacer Scroll
    // -------------------------------------------------------------------------
    const navbar = document.getElementById('navbar');
    
    // Evitar añadir múltiples listeners si se navega varias veces
    const handleScroll = () => {
      if (window.scrollY > 20) {
        navbar?.classList.remove('bg-[#0a0a0a]/85', 'border-red-600/15');
        navbar?.classList.add('bg-[#0a0a0a]/97', 'border-red-600/30');
      } else {
        navbar?.classList.remove('bg-[#0a0a0a]/97', 'border-red-600/30');
        navbar?.classList.add('bg-[#0a0a0a]/85', 'border-red-600/15');
      }
    };
    
    // Limpiamos y añadimos para evitar duplicados
    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll, { passive: true });

    // Ejecutar una vez al inicio por si ya estamos scrolleados
    handleScroll();

    // -------------------------------------------------------------------------
    // Lógica del Menú Móvil (Abrir/Cerrar)
    // -------------------------------------------------------------------------
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu   = document.getElementById('mobile-menu');

    toggle?.addEventListener('click', () => {
      const isHidden = menu?.classList.contains('hidden');
      if (isHidden) {
        menu?.classList.remove('hidden');
        menu?.classList.add('animate-fade-in-down', 'animate-duration-fast');
        toggle.setAttribute('aria-expanded', 'true');
      } else {
        menu?.classList.add('hidden');
        menu?.classList.remove('animate-fade-in-down', 'animate-duration-fast');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    // -------------------------------------------------------------------------
    // Cerrar el menú móvil automáticamente al hacer clic en un enlace
    // -------------------------------------------------------------------------
    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });
  });
</script>
