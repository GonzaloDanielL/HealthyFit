---
const footerLinks = {
  gym: [
    { href: '/nosotros',  label: 'Nosotros' },
    { href: '/servicios', label: 'Servicios' },
    { href: '/galeria',   label: 'Galería' },
  ],
  members: [
    { href: '/planes',   label: 'Planes y Precios' },
    { href: '/contacto', label: 'Contacto' },
    { href: '#',         label: 'Área de miembros' },
  ],
};

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#111111] border-t border-[#2a2a2a] pt-16 mt-16">
  <div class="container-site">

    <!-- Top: Logo + Links -->
    <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-10 md:gap-16 pb-12 border-b border-[#2a2a2a]">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-2 no-underline mb-4" aria-label="HealthyFit">
          <span class="w-8 h-8 bg-red-600 text-white grid place-items-center font-display font-black text-lg rounded-md">H</span>
          <span class="font-display text-xl font-semibold text-white">
            Healthy<strong class="text-red-600 font-extrabold">Fit</strong>
          </span>
        </a>
        <p class="text-[#a1a1a1] text-sm leading-[1.6] mb-6">
          Transforma tu cuerpo.<br/>Transforma tu vida.
        </p>
        <div class="flex gap-3">
          <a href="#" class="w-9 h-9 rounded-full bg-[#1a1a1a] border border-[#2a2a2a] grid place-items-center text-[#a1a1a1] no-underline transition-all duration-200 hover:text-red-400 hover:bg-red-600/10 hover:border-red-600" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-[#1a1a1a] border border-[#2a2a2a] grid place-items-center text-[#a1a1a1] no-underline transition-all duration-200 hover:text-red-400 hover:bg-red-600/10 hover:border-red-600" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-[#1a1a1a] border border-[#2a2a2a] grid place-items-center text-[#a1a1a1] no-underline transition-all duration-200 hover:text-red-400 hover:bg-red-600/10 hover:border-red-600" aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div>
          <h3 class="font-display text-sm font-bold text-white uppercase tracking-[0.08em] mb-4">El Gimnasio</h3>
          <ul class="list-none flex flex-col gap-2.5">
            {footerLinks.gym.map(link => (
              <li><a href={link.href} class="text-[#a1a1a1] no-underline text-sm transition-colors duration-200 hover:text-red-400">{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-display text-sm font-bold text-white uppercase tracking-[0.08em] mb-4">Miembros</h3>
          <ul class="list-none flex flex-col gap-2.5">
            {footerLinks.members.map(link => (
              <li><a href={link.href} class="text-[#a1a1a1] no-underline text-sm transition-colors duration-200 hover:text-red-400">{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-display text-sm font-bold text-white uppercase tracking-[0.08em] mb-4">Horarios</h3>
          <ul class="list-none flex flex-col gap-2">
            <li class="flex justify-between text-sm text-[#a1a1a1]"><span>Lun – Vie</span><span class="text-white font-semibold">6:00 – 23:00</span></li>
            <li class="flex justify-between text-sm text-[#a1a1a1]"><span>Sábado</span><span class="text-white font-semibold">7:00 – 21:00</span></li>
            <li class="flex justify-between text-sm text-[#a1a1a1]"><span>Domingo</span><span class="text-white font-semibold">8:00 – 18:00</span></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row items-center justify-between py-5 gap-3 text-center md:text-left">
      <p class="text-xs text-[#6b6b6b]">
        &copy; {currentYear} HealthyFit. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-[#6b6b6b] no-underline transition-colors duration-200 hover:text-[#a1a1a1]">Privacidad</a>
        <a href="#" class="text-xs text-[#6b6b6b] no-underline transition-colors duration-200 hover:text-[#a1a1a1]">Términos</a>
      </div>
    </div>
  </div>
</footer>
