---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
}

const { title, subtitle, description } = Astro.props;
---

<section class="bg-gradient-to-br from-red-600/10 to-transparent bg-[#111111] border-b border-[#2a2a2a] pt-20 pb-16 text-center">
  <div class="container-site">
    {subtitle && (
      <span class="block text-xs font-bold uppercase tracking-[0.14em] text-red-400 mb-3">
        {subtitle}
      </span>
    )}
    
    <h1 
      class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] font-black text-white leading-[1.05] mb-5"
      set:html={title}
    />
    
    {description && (
      <p class="text-[1.05rem] text-[#a1a1a1] max-w-[36rem] mx-auto leading-[1.7]">
        {description}
      </p>
    )}
  </div>
</section>
