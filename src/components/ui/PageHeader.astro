---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  bgImage: ImageMetadata;
}

const { title, subtitle, description, bgImage } = Astro.props;
---

<section class="relative border-b border-[#2a2a2a] pt-20 pb-16 text-center overflow-hidden">
  <!-- Background Image with Blur -->
  <Image 
    src={bgImage} 
    alt="" 
    class="absolute inset-0 w-full h-full object-cover blur-[6px] scale-110"
    loading="eager"
    decoding="sync"
  />
  
  <!-- Dark overlay to ensure text readability -->
  <div class="absolute inset-0 bg-[#111111]/80"></div>
  
  <!-- Subtle red gradient overlay to match the original style -->
  <div class="absolute inset-0 bg-gradient-to-br from-red-600/20 to-transparent"></div>

  <div class="container-site relative z-10">
    {subtitle && (
      <span class="block text-xs font-bold uppercase tracking-[0.14em] text-red-400 mb-3">
        {subtitle}
      </span>
    )}
    
    <h1 
      class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] font-black text-white leading-[1.05] mb-5"
      set:html={title}
    />
    
    {description && (
      <p class="text-[1.05rem] text-[#a1a1a1] max-w-[36rem] mx-auto leading-[1.7]">
        {description}
      </p>
    )}
  </div>
</section>
