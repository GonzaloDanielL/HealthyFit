---
import { Image } from 'astro:assets';

interface Props {
  image: any; // Image metadata o URL
  title: string;
  description: string;
  href: string;
  linkText?: string;
}

const { 
  image, 
  title, 
  description, 
  href, 
  linkText = 'Ver más →' 
} = Astro.props;
---

<div class="group bg-[#1a1a1a] border border-[#2a2a2a] rounded-xl overflow-hidden flex flex-col transition-all duration-200 hover:border-red-500/40 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
  <!-- Imagen -->
  <div class="w-full aspect-[3/2] overflow-hidden">
    <Image
      src={image}
      alt={title}
      width={600}
      height={400}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <!-- Texto -->
  <div class="flex flex-col flex-1 p-6">
    <h3 class="font-display text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-sm text-[#a1a1a1] leading-relaxed mb-5 flex-1">{description}</p>
    <a
      href={href}
      class="self-start text-xs font-bold text-red-400 uppercase tracking-[0.06em] hover:text-red-500 transition-colors duration-200"
    >
      {linkText}
    </a>
  </div>
</div>
